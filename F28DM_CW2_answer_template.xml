    <question id="4">
        <answer>2500324</answer>
        <sql>
          <![CDATA[
SELECT ma2.actorid
FROM imdb.actors a
JOIN imdb.movies2actors ma1 ON a.actorid = ma1.actorid
JOIN imdb.movies2actors ma2 ON ma1.movieid = ma2.movieid
WHERE a.name = 'Hanks, Tom'
  AND ma2.actorid != ma1.actorid
GROUP BY ma2.actorid
ORDER BY COUNT(*) DESC
LIMIT 1;
]]>
        </sql>
    </question>

    <question id="5">
        <answer>3</answer>
        <sql>
          <![CDATA[
        WITH pairs AS (
    SELECT ma1.actorid AS actor_a, ma2.actorid AS actor_b
    FROM imdb.movies2actors ma1
    JOIN imdb.movies2actors ma2
        ON ma1.movieid = ma2.movieid
        AND ma1.actorid < ma2.actorid
    GROUP BY ma1.actorid, ma2.actorid
    HAVING COUNT(*) > 10
)
SELECT COUNT(DISTINCT actorid)
FROM (
    SELECT actor_a AS actorid FROM pairs
    UNION
    SELECT actor_b AS actorid FROM pairs
) all_actors;
]]>
        </sql>
    </question>

